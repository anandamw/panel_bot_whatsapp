
<div class="mb-6 flex justify-between items-center">
    <div>
        <h2 class="text-2xl font-bold text-gray-800">Bot Details</h2>
        <p class="text-gray-500 text-sm">Session: <%= bot.session_id %> | Phone: <%= bot.phone_number || 'Unknown' %></p>
    </div>
    <div class="flex items-center gap-2">
        <a href="/bots/<%= bot.session_id %>/refresh" class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2" onclick="return confirm('Ini akan logout session dan memunculkan QR baru. Data grup akan tetap tersimpan. Lanjutkan?')">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            Re-Scan QR
        </a>
        <a href="/" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Dashboard
        </a>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-8">
    <div class="p-6 border-b border-gray-100 flex justify-between items-center">
        <h3 class="text-lg font-semibold text-gray-800">Joined Groups</h3>
        <span class="bg-whatsapp-light/10 text-whatsapp px-3 py-1 rounded-full text-xs font-bold">
            <%= groups.length %> Groups
        </span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-gray-50 text-gray-600 text-xs uppercase font-semibold">
                <tr>
                    <th class="px-6 py-4">Group Name</th>
                    <th class="px-6 py-4">Group ID</th>
                    <th class="px-6 py-4">Link</th>
                    <th class="px-6 py-4">Joined At</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% if(groups.length === 0) { %>
                    <tr>
                        <td colspan="4" class="px-6 py-10 text-center text-gray-500">
                            Bot hasn't joined any groups yet.
                        </td>
                    </tr>
                <% } else { %>
                    <% groups.forEach(group => { %>
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4 font-medium text-gray-800"><%= group.group_name %></td>
                        <td class="px-6 py-4 text-sm text-gray-500"><%= group.group_id %></td>
                        <td class="px-6 py-4 text-sm text-whatsapp truncate max-w-xs">
                            <a href="<%= group.group_link %>" target="_blank" class="hover:underline"><%= group.group_link %></a>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-500">
                            <%= new Date(group.created_at).toLocaleString() %>
                        </td>
                    </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
