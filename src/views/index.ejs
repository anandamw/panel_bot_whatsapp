

<div class="mb-6 flex justify-between items-center">
    <div>
        <h2 class="text-2xl font-bold text-gray-800">Dashboard</h2>
        <p class="text-gray-500 text-sm">Overview of your WhatsApp Bots</p>
    </div>
    <a href="/bots/add" class="bg-whatsapp hover:bg-whatsapp-dark text-white px-4 py-2 rounded-lg text-sm font-medium transition shadow-sm flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Add New Bot
    </a>
</div>

<div class="grid gap-6 mb-8 md:grid-cols-2 xl:grid-cols-4">
    <!-- Stat Card: Active Bots -->
    <div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100 hover:shadow-md transition-shadow relative overflow-hidden group">
        <div class="absolute top-0 right-0 -mr-4 -mt-4 w-24 h-24 bg-green-50 rounded-full opacity-50 group-hover:scale-110 transition-transform"></div>
        <div class="flex items-center relative z-10">
            <div class="p-4 rounded-xl bg-green-50 text-green-600 shadow-inner">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div class="ml-5">
                <p class="mb-1 text-sm font-semibold text-gray-500 uppercase tracking-wider">Active Bots</p>
                <div class="flex items-baseline gap-2">
                    <p class="text-3xl font-extrabold text-gray-800"><%= bots.filter(b => b.status === 'connected').length %></p>
                    <span class="text-xs font-medium text-green-500 bg-green-50 px-2 py-0.5 rounded-full">Online</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Stat Card: Total Groups -->
    <div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100 hover:shadow-md transition-shadow relative overflow-hidden group">
        <div class="absolute top-0 right-0 -mr-4 -mt-4 w-24 h-24 bg-whatsapp-light/5 rounded-full opacity-50 group-hover:scale-110 transition-transform"></div>
        <div class="flex items-center relative z-10">
            <div class="p-4 rounded-xl bg-whatsapp-light/10 text-whatsapp shadow-inner">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <div class="ml-5">
                <p class="mb-1 text-sm font-semibold text-gray-500 uppercase tracking-wider">Total Groups</p>
                <div class="flex items-baseline gap-2">
                    <p class="text-3xl font-extrabold text-gray-800"><%= bots.reduce((sum, bot) => sum + (bot.group_count || 0), 0) %></p>
                    <span class="text-xs font-medium text-whatsapp bg-whatsapp-light/10 px-2 py-0.5 rounded-full">Shared</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Recent Activity -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden h-full">
            <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-lg font-bold text-gray-800">Recent Activity</h3>
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div class="p-6">
                <% if(recentGroups.length === 0) { %>
                    <div class="text-center py-8">
                        <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                        </div>
                        <p class="text-gray-400 text-sm italic">No recent activity found.</p>
                    </div>
                <% } else { %>
                    <div class="space-y-6">
                        <% recentGroups.forEach(group => { %>
                        <div class="flex gap-4 relative">
                            <!-- Timeline line -->
                            <div class="absolute left-[19px] top-10 bottom-[-24px] w-0.5 bg-gray-100 last:hidden"></div>
                            
                            <div class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-whatsapp-light/10 border-4 border-white flex items-center justify-center text-whatsapp shadow-sm">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-bold text-gray-800 truncate"><%= group.group_name %></p>
                                <p class="text-xs text-gray-500 mb-1">Via: <%= group.phone_number %></p>
                                <span class="text-[10px] text-gray-400 font-medium"><%= new Date(group.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Bot Sessions Table -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden h-full">
            <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-lg font-bold text-gray-800">Bot Sessions</h3>
                <span class="bg-blue-50 text-blue-600 px-3 py-1 rounded-full text-xs font-bold ring-1 ring-blue-100"><%= bots.length %> Total</span>
            </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-gray-50 text-gray-600 text-xs uppercase font-semibold">
                <tr>
                    <th class="px-6 py-4">No. HP</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Joined Groups</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% if(bots.length === 0) { %>
                    <tr>
                        <td colspan="4" class="px-6 py-10 text-center text-gray-500">
                            No bots connected yet. <a href="/bots/add" class="text-whatsapp hover:underline">Add one?</a>
                        </td>
                    </tr>
                <% } else { %>
                    <% bots.forEach(bot => { %>
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4 font-medium text-gray-800"><%= bot.phone_number || 'Unknown' %></td>
                        <td class="px-6 py-4">
                            <span class="px-2 py-1 text-xs font-semibold rounded-full 
                                <%= bot.status === 'connected' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                                <%= bot.status %>
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-600">
                            <div class="flex items-center gap-2">
                                <span class="bg-whatsapp-light/10 text-whatsapp px-2 py-0.5 rounded-full text-xs font-bold">
                                    <%= bot.group_count %> Groups
                                </span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right flex justify-end gap-2">
                            <a href="/bots/<%= bot.session_id %>" class="text-gray-400 hover:text-whatsapp transition p-1.5" title="View Details">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                            </a>
                            <button onclick="openJoinModal('<%= bot.session_id %>')" class="bg-whatsapp-light/10 text-whatsapp hover:bg-whatsapp-light/20 px-3 py-1.5 rounded-lg text-xs font-bold transition flex items-center gap-1" title="Join New Group">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                Join Group
                            </button>
                            <button onclick="deleteBot('<%= bot.session_id %>')" class="text-gray-400 hover:text-red-500 transition p-1.5" title="Delete Bot">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </td>

                    </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
</div>
<%- %>

<!-- Join Group Modal -->
<div id="joinModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full flex items-center justify-center">
    <div class="relative p-5 border w-96 shadow-lg rounded-md bg-white">
        <div class="mt-3 text-center">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Join Group</h3>
            <div class="mt-2 px-7 py-3">
                <input type="hidden" id="joinSessionId">
                <input type="text" id="groupLink" placeholder="https://chat.whatsapp.com/..." 
                       class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-whatsapp">
                <p class="text-xs text-gray-500 mt-2 text-left">Paste the group invite link here.</p>
            </div>
            <div class="items-center px-4 py-3">
                <button id="joinBtn" class="px-4 py-2 bg-whatsapp text-white text-base font-medium rounded-md w-full shadow-sm hover:bg-whatsapp-dark focus:outline-none focus:ring-2 focus:ring-whatsapp-light">
                    Join Group
                </button>
                <button onclick="closeModal()" class="mt-3 px-4 py-2 bg-gray-100 text-gray-700 text-base font-medium rounded-md w-full shadow-sm hover:bg-gray-200">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function openJoinModal(sessionId) {
        document.getElementById('joinSessionId').value = sessionId;
        document.getElementById('joinModal').classList.remove('hidden');
    }

    function closeModal() {
        document.getElementById('joinModal').classList.add('hidden');
        document.getElementById('joinSessionId').value = '';
        document.getElementById('groupLink').value = '';
    }

    document.getElementById('joinBtn').addEventListener('click', async () => {
        const sessionId = document.getElementById('joinSessionId').value;
        const groupLink = document.getElementById('groupLink').value;
        const btn = document.getElementById('joinBtn');
        
        if(!groupLink) return Swal.fire('Oops...', 'Please enter a group link', 'warning');

        btn.innerText = 'Joining...';
        btn.disabled = true;

        try {
            const res = await fetch('/bots/join', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sessionId, groupLink })
            });
            const data = await res.json();
            
            if(data.success) {
                await Swal.fire('Success!', 'Joined group successfully', 'success');
                location.reload();
            } else {
                Swal.fire('Failed', data.message, 'error');
            }
        } catch(e) {
            Swal.fire('Error', 'Failed to join group', 'error');
        } finally {
            btn.innerText = 'Join Group';
            btn.disabled = false;
            closeModal();
        }
    });

    async function deleteBot(sessionId) {
        const result = await Swal.fire({
            title: 'Are you sure?',
            text: "This will disconnect the bot session permanently!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#34B7F1',
            confirmButtonText: 'Yes, delete it!'
        });

        if (!result.isConfirmed) return;

        try {
            const res = await fetch(`/bots/${sessionId}`, { method: 'DELETE' });
            const data = await res.json();
            if(data.success) {
                await Swal.fire('Deleted!', 'Bot has been disconnected.', 'success');
                location.reload();
            } else {
                Swal.fire('Error', data.message, 'error');
            }
        } catch(e) {
            Swal.fire('Error', 'Failed to delete bot', 'error');
        }
    }
</script>
